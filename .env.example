# ============================================================
# VLM + Visual RAG + Agentic RAG - 環境変数
# ============================================================
# このファイルを `.env` にコピーして値を設定してください:
#   cp .env.example .env
# ============================================================

# HuggingFace Token (モデルダウンロード用)
HF_TOKEN=

# API認証キー (空の場合は認証スキップ = 開発モード)
API_KEY=

# CORS許可オリジン (カンマ区切り)
ALLOWED_ORIGINS=https://*.run.app,http://localhost:3000,http://localhost:8080

# モデルキャッシュ
TRANSFORMERS_CACHE=/models
HF_HOME=/models

# GPU設定
CUDA_VISIBLE_DEVICES=0
